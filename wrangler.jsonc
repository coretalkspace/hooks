{
  "name": "hooks",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-25",

  "vars": {
    "MISSKEY_ORIGIN": "https://coretalk.space"
  },

  // MISSKEY_TOKEN: wrangler secret put MISSKEY_TOKEN
  // ALLOWED_IPS: wrangler secret put ALLOWED_IPS (JSON string or array)

  "routes": [
    {
      "pattern": "hooks.coretalk.space",
      "custom_domain": true
    }
  ],

  "observability": {
    "enabled": true
  }
}
